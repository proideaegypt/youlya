# Youlya AI Commerce OS — environment template
# Copy to .env.local for local development.
# Never commit .env.local or production secret files.

# ------------------------------------------------------------
# App
# ------------------------------------------------------------
NODE_ENV=development
APP_ENV=local
APP_URL=http://localhost:3000
APP_PUBLIC_URL=https://admin.example.com
NEXT_PUBLIC_APP_NAME=Youlya AI Commerce OS
NEXT_PUBLIC_DEFAULT_LOCALE=ar-EG
DEFAULT_STORE_SLUG=youlya
DEFAULT_TIMEZONE=Africa/Cairo

# testMode/mock mode
MOCK_MODE=true
ALLOW_TEST_MODE=true
INTERNAL_API_SECRET=replace-with-long-random-secret
WEBHOOK_SIGNING_SECRET=replace-with-long-random-secret

# ------------------------------------------------------------
# Supabase
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-service-role-key
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ------------------------------------------------------------
# Shopify
# ------------------------------------------------------------
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ADMIN_API_VERSION=2026-04
SHOPIFY_ADMIN_ACCESS_TOKEN=replace-with-admin-token
SHOPIFY_WEBHOOK_SECRET=replace-with-webhook-secret
SHOPIFY_USE_GRAPHQL=true
SHOPIFY_MOCK_ORDERS=true
SHOPIFY_COD_FINANCIAL_STATUS=pending
SHOPIFY_ORDER_TAGS=whatsapp,cod,YoulyaAI,AI-confirmed
SHOPIFY_ORDER_NOTE_PREFIX=Made By YOULYAAI

# Product code policy
SHOPIFY_PRODUCT_CODE_SOURCE=variant_sku
SHOPIFY_REQUIRE_VARIANT_SKU_FOR_AI_VISIBILITY=true
SHOPIFY_CODE_MISSING_BEHAVIOR=flag_not_block

# ------------------------------------------------------------
# Evolution API / WhatsApp
# ------------------------------------------------------------
EVOLUTION_API_URL=https://evolution.example.com
EVOLUTION_API_KEY=replace-with-evolution-api-key
EVOLUTION_INSTANCE_NAME=YOUR_INSTANCE
EVOLUTION_WEBHOOK_URL=https://app.example.com/api/webhooks/evolution
EVOLUTION_SEND_TIMEOUT_MS=15000
EVOLUTION_MEDIA_TIMEOUT_MS=10000
EVOLUTION_MAX_IMAGE_SEND=10
EVOLUTION_RETRY_MAX=3
EVOLUTION_RETRY_BACKOFF_MS=1000

# ------------------------------------------------------------
# n8n
# ------------------------------------------------------------
N8N_BASE_URL=https://n8n.example.com
N8N_WEBHOOK_BASE_URL=https://n8n.example.com/webhook
N8N_API_KEY=replace-with-n8n-api-key-if-used
N8N_BASIC_AUTH_USER=replace-with-user
N8N_BASIC_AUTH_PASSWORD=replace-with-password

# ------------------------------------------------------------
# AI
# ------------------------------------------------------------
OPENAI_API_KEY=replace-with-openai-api-key
OPENAI_MODEL=gpt-5.3-codex
OPENAI_TRANSCRIPTION_MODEL=whisper-1
AI_TEMPERATURE=0.2
AI_MAX_TOOL_RETRIES=1
AI_MAX_UNCLEAR_TURNS=3

# ------------------------------------------------------------
# Commerce rules
# ------------------------------------------------------------
SHIPPING_CAIRO_EGP=70
SHIPPING_ALEXANDRIA_EGP=90
FREE_SHIPPING_THRESHOLD_EGP=1200
MAX_CART_ITEMS=5
MAX_ORDER_VALUE_BEFORE_HANDOFF_EGP=5000
REQUIRE_EXPLICIT_CONFIRMATION=true
ALLOW_AMBIGUOUS_CONFIRM_AFTER_SUMMARY=true

# ------------------------------------------------------------
# Dashboard / Auth
# ------------------------------------------------------------
DASHBOARD_ENABLED=false
DASHBOARD_AUTH_PROVIDER=supabase
OWNER_EMAIL=owner@example.com
ADMIN_NOTIFICATION_EMAIL=alerts@example.com
ADMIN_NOTIFICATION_WHATSAPP=201000000000

# ------------------------------------------------------------
# Security / Ops
# ------------------------------------------------------------
LOG_LEVEL=info
PII_LOGGING_MODE=masked
AUDIT_LOG_RETENTION_DAYS=365
ERROR_ALERTS_ENABLED=true
KILL_SWITCH_DEFAULT=false
AI_ORDER_CREATION_ENABLED=false


PORTAINER_URL=https://port.youlya.com
PORTAINER_API_KEY=ptr_NF9FELiBD4tedjQgc0OUkH/HCcUpn7cVfdXTBhY1E8M=
PORTAINER_STACK_ID=youlya
DASHBOARD_HEALTH_URL=https://admin.youlya.com/api/health